---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import espresso_tools from "../images/espresso-tools.webp";
import pour_coffee from "../images/pour-coffee.webp";
---

<BaseLayout title = "Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Side projects</div>
  </div>
	<HorizontalCard
			title="Espresso Tools wishlist"
			img={espresso_tools}
			desc="Curated collection of espresso gear I use, love, or dream of owning. From machines and grinders to the small accessories that make a big difference."
			url="https://espresso.tools"
			badge="Espresso"
	/>
	<div class="divider my-0"></div>
	<HorizontalCard
			title="Pour Over Coffee guide"
			img={pour_coffee}
			desc="A pour over brewing guide with recipes, troubleshooting, and gear recommendations. Built to make great coffee feel approachable."
			url="https://pour.coffee"
			badge="Pour Over"
	/>
</BaseLayout>
